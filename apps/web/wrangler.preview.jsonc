{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "seriesav-web-preview",
  "main": "./dist/server/server.js",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "preview"
  },
  "routes": [
    {
      "pattern": "app.series-av-preview.avalsys.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application"
  }
}
