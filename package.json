{
  "name": "seriesav",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "vp run dev",
    "dev": "vp run ios:build",
    "web": "vp run --filter ./apps/web dev",
    "web:dev": "vp run --filter ./apps/web dev",
    "web:build": "vp run --filter ./apps/web build",
    "web:deploy:preview": "vp run --filter ./apps/web deploy:preview",
    "web:deploy:production": "vp run --filter ./apps/web deploy:production",
    "web:deploy:preview:dry-run": "vp run --filter ./apps/web deploy:preview:dry-run",
    "web:deploy:production:dry-run": "vp run --filter ./apps/web deploy:production:dry-run",
    "web:typecheck": "vp run --filter ./apps/web typecheck",
    "ios": "vp run ios:build",
    "varlock:load": "zsh -lc 'eval \"$(./scripts/resolve-infisical-bootstrap-env.sh local)\" && ./node_modules/.bin/varlock load --path .'",
    "varlock:load:preview": "zsh -lc 'eval \"$(./scripts/resolve-infisical-bootstrap-env.sh preview)\" && ./node_modules/.bin/varlock load --path .'",
    "varlock:load:production": "zsh -lc 'eval \"$(./scripts/resolve-infisical-bootstrap-env.sh production)\" && ./node_modules/.bin/varlock load --path .'",
    "varlock:typegen": "echo 'No TypeScript env types are generated for the native iOS app.'",
    "config:hygiene": "./scripts/check-public-config-hygiene.sh",
    "copy:audit": "node scripts/check-localized-copy.mjs",
    "ios:config": "./scripts/generate-local-xcconfig.sh local",
    "ios:config:preview": "./scripts/generate-local-xcconfig.sh preview",
    "ios:config:production": "./scripts/generate-local-xcconfig.sh production",
    "ios:preflight": "./scripts/verify-ios-runtime-config.sh local",
    "ios:preflight:preview": "./scripts/verify-ios-runtime-config.sh preview",
    "ios:preflight:production": "./scripts/verify-ios-runtime-config.sh production",
    "ios:build": "xcodebuild -project apps/ios/SeriesAV.xcodeproj -scheme SeriesAV -destination 'generic/platform=iOS Simulator' -configuration Debug -derivedDataPath .DerivedData-ios build CODE_SIGNING_ALLOWED=NO",
    "ios:release:simulator": "./scripts/check-ios-release-simulator-gate.sh",
    "ios:archive:check": "./scripts/check-ios-release-archive.sh",
    "ios:release:archive": "./scripts/ios-release-archive-upload.sh",
    "ios:release:upload": "./scripts/ios-release-archive-upload.sh",
    "typecheck": "vp run ios:build && vp run web:typecheck",
    "check": "vp run copy:audit && vp run typecheck",
    "deps:outdated": "ncu --workspaces --packageManager pnpm --cooldown 1",
    "deps:audit": "pnpm audit",
    "ncu": "ncu --workspaces --packageManager pnpm --target latest --cooldown 1 -u && vp run clean",
    "ncu:minor": "ncu --workspaces --packageManager pnpm --target minor --cooldown 1 -u && vp run clean",
    "update": "vp run ncu",
    "update:minor": "vp run ncu:minor",
    "clean": "vp run clean:files && pnpm install && vp run clean:cache",
    "clean:files": "rm -rf node_modules dist coverage",
    "clean:cache": "pnpm store prune"
  },
  "devDependencies": {
    "@varlock/infisical-plugin": "0.0.6",
    "varlock": "^0.9.1",
    "vite-plus": "0.2.2",
    "wrangler": "^4.101.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0",
      "onFail": "download"
    }
  }
}
